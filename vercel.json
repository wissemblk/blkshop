{
  "version": 2,
  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "zeroConfig": true
      }
    },
    {
      "src": "backend/**",
      "use": "@vercel/node",
      "config": {
        "zeroConfig": true
      }
    }
  ]
}